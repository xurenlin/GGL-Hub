# ============================================
# GGL-Hub 企业级全球化智能物流调度平台
# 环境变量配置文件
# ============================================

# ========== 通用配置 ==========
PROJECT_NAME=GGL-Hub
PROJECT_VERSION=1.0.0-SNAPSHOT
ENVIRONMENT=dev
TIMEZONE=Asia/Shanghai
LANGUAGE=zh-CN

# ========== 网络配置 ==========
NETWORK_NAME=ggl-network
HOST_IP=192.168.1.100

# ========== Nacos 配置 ==========
NACOS_SERVER_ADDR=nacos:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# ========== MySQL 配置 ==========
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE_PREFIX=ggl

# ========== Redis 配置 ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=123456
REDIS_DATABASE=0

# ========== 服务端口配置 ==========
GATEWAY_PORT=8080
ORDER_SERVICE_PORT=8081
GEO_SERVICE_PORT=8082
I18N_SERVICE_PORT=8083
RAG_SERVICE_PORT=8084
GUARDRAIL_SERVICE_PORT=8085
AI_GATEWAY_PORT=8086

# ========== AI 服务配置 ==========
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=your-anthropic-api-key
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAME=llama2
HUGGING_FACE_API_KEY=your-hugging-face-api-key
HUGGING_FACE_MODEL_ID=your-model-id

# ========== 监控配置 ==========
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_PORT=16686

# ========== 对象存储配置 ==========
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=ggl-bucket
# 注意：容器内部端口仍然是 9000，外部访问端口改为 9002
MINIO_EXTERNAL_ENDPOINT=http://localhost:9002

# ========== 日志配置 ==========
ELASTICSEARCH_HOST=http://elasticsearch:9200
KIBANA_HOST=http://kibana:5601
LOGSTASH_HOST=logstash:5000

# ========== 安全配置 ==========
JWT_SECRET=ggl-hub-jwt-secret-key-2024-change-this-in-production
JWT_EXPIRATION=86400000
ENCRYPTION_KEY=ggl-hub-encryption-key-2024-change-this

# ========== 性能配置 ==========
MAX_CONNECTIONS=1000
CONNECTION_TIMEOUT=30000
READ_TIMEOUT=60000
WRITE_TIMEOUT=60000

# ========== 开发配置 ==========
DEBUG=true
PROFILE=dev
LOG_LEVEL=DEBUG
